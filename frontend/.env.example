# Firebase Authentication (optional — leave blank for local dev without auth)
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Backend API URL (optional — defaults to "/" which uses Vite proxy in dev)
# Set to your GCP VM domain in production, e.g. https://api.yourdomain.com
VITE_API_BASE_URL=
