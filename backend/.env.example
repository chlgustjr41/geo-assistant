# ── Required API Keys ────────────────────────────────────────────────────────
# At least ONE of the following must be set. Cheapest option: GOOGLE_API_KEY.
#
# OpenAI (GPT-4o, GPT-4.1, GPT-4.1-Mini)
# Get key at: https://platform.openai.com/api-keys
# Key format: sk-proj-... or sk-...
OPENAI_API_KEY=

# Google Gemini (Gemini 2.5 Flash Lite, Flash, Pro) — RECOMMENDED default
# Get key at: https://aistudio.google.com/app/apikey
# Key format: AIza...
GOOGLE_API_KEY=

# Anthropic Claude (Claude Sonnet 4.6, Opus 4.6, Haiku 4.5)
# Get key at: https://console.anthropic.com/settings/keys
# Key format: sk-ant-...
ANTHROPIC_API_KEY=

# ── Optional Settings ─────────────────────────────────────────────────────────
# Default GE model shown on first load. Must be one of the model IDs listed in
# frontend/src/types/index.ts GE_MODELS.
DEFAULT_MODEL=gemini-2.5-flash-lite

# Pre-select a rule set on startup (optional — leave blank to use first available)
DEFAULT_RULE_SET=

# ── Authentication (optional — leave blank to disable auth in local dev) ──────
# Path to Firebase Admin SDK service account JSON.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=

# Comma-separated list of Google account emails allowed to use the app.
# When empty, authentication is disabled (open access for local development).
ALLOWED_EMAILS=

# ── Deployment ────────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins. Defaults to localhost dev servers.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
